{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isPro": { "type": "boolean" },
        "proExpirationDate": { "type": "string", "format": "date-time" },
        "planType": { "type": "string", "enum": ["gratuito", "7 dias", "1 ano", "vitalício"] },
        "profileType": { "type": "string", "enum": ["Perfil Genérico", "Agente de Segurança", "Professor", "Voluntário em ONG", "Profissional da Saúde", "Turista", "Figura Pública"] }
      },
      "required": ["uid", "email"]
    },
    "Contact": {
      "title": "Contact",
      "description": "Emergency contact information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["Polícia", "Hospital", "Advogado", "Outro"] },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "isOfficial": { "type": "boolean" },
        "location": { "type": "string" }
      },
      "required": ["name", "phone", "type"]
    },
    "ChecklistItem": {
      "title": "ChecklistItem",
      "description": "Security checklist item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "text": { "type": "string" },
        "completed": { "type": "boolean" },
        "isDefault": { "type": "boolean" },
        "order": { "type": "integer" },
        "profile": { "type": "string" }
      },
      "required": ["userId", "text", "completed"]
    },
    "GuideContent": {
      "title": "GuideContent",
      "description": "Educational security content",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "section": { "type": "string", "enum": ["Planejamento", "Prevenção", "Análise"] },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "order": { "type": "integer" },
        "profile": { "type": "string" }
      },
      "required": ["section", "title", "content"]
    },
    "PendingProGrant": {
      "title": "PendingProGrant",
      "description": "Pro access grant for a user who hasn't signed up yet",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "duration": { "type": "string", "enum": ["7days", "1year", "lifetime"] },
        "planType": { "type": "string", "enum": ["7 dias", "1 ano", "vitalício"] },
        "proExpirationDate": { "type": "string", "format": "date-time" },
        "grantedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "duration", "grantedAt"]
    },
    "JournalEntry": {
      "title": "JournalEntry",
      "description": "User journal or diary entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "content", "createdAt"]
    },
    "Incident": {
      "title": "Incident",
      "description": "User reported security incident",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": [
          "Crimes Contra o Patrimônio (Roubos e Furtos)",
          "Roubo de Celular",
          "Furto por Distração (Pickpocketing)",
          "Arrastões",
          "Violência ou Abordagens Agressivas",
          "Assalto à Mão Armada",
          "Violência contra transeuntes",
          "Roubo de veículos",
          "Riscos de Trânsito e Mobilidade",
          "Atropelamentos",
          "Acidentes de Bicicleta/Moto",
          "Rotas Obstruídas",
          "Iluminação Precária ou Inexistente",
          "Área de risco para emergências naturais",
          "Desastres naturais",
          "Incêndio",
          "Atividade Suspeita",
          "Ação de Gangues",
          "Risco alto de sequestro",
          "Assalto a veículos",
          "Outros"
        ] },
        "description": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "locationName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "latitude", "longitude", "locationName", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/contacts/{contactId}": {
      "schema": "Contact",
      "description": "Emergency contacts"
    },
    "/checklist/{itemId}": {
      "schema": "ChecklistItem",
      "description": "User checklist items"
    },
    "/guides/{guideId}": {
      "schema": "GuideContent",
      "description": "Educational content"
    },
    "/pending_pro_grants/{email}": {
      "schema": "PendingProGrant",
      "description": "Pending Pro access grants"
    },
    "/settings/{settingId}": {
      "schema": "object",
      "description": "Application settings and versioning"
    },
    "/journal_entries/{entryId}": {
      "schema": "JournalEntry",
      "description": "User journal entries"
    },
    "/incidents/{incidentId}": {
      "schema": "Incident",
      "description": "User reported security incidents"
    }
  }
}
